

echo "🛡️  Running Security Pre-commit Hook..."

# Find all staged files
STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Define the forbidden patterns
FORBIDDEN_ENV="\.env$"
FORBIDDEN_JSON="service-account.*\.json$"

BLOCK_COMMIT=0

for file in $STAGED_FILES; do
  # Skip .env.example
  if echo "$file" | grep -q "\.env\.example$"; then
    continue
  fi

  if echo "$file" | grep -qE "$FORBIDDEN_ENV"; then
    echo "❌ SECURITY ERROR: You are attempting to commit an environment file: $file"
    BLOCK_COMMIT=1
  fi

  if echo "$file" | grep -qE "$FORBIDDEN_JSON"; then
    echo "❌ SECURITY ERROR: You are attempting to commit a private JSON key file: $file"
    BLOCK_COMMIT=1
  fi
done

if [ $BLOCK_COMMIT -eq 1 ]; then
  echo "🚫 Commit blocked! Please remove these sensitive files from staging using 'git reset HEAD <file>'"
  echo "   and ensure they are properly ignored in your .gitignore file."
  exit 1
fi

echo "✅ Security check passed!"
